                local frame = gui:FindFirstChildOfClass("Frame")
                if frame then
                    for _, d in ipairs(frame:GetDescendants()) do
                        if d:IsA("UIStroke") then
                            local g = d:FindFirstChildOfClass("UIGradient")
                            if not g then
