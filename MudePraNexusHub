        _G._FH_ThemeCallbacks = _G._FH_ThemeCallbacks or {}
        table.insert(_G._FH_ThemeCallbacks, _fixAutoGrabBarTheme)
        pcall(_fixAutoGrabBarTheme)
    end

    local function applyGuiState()
        if not GUI then return end
        if not enabled then

            GUI.Enabled = true
            restoreAllESPs()
            showMiniPets()
            showProgressBar()
            return
