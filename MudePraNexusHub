-- NEXUS HUB - COMPLETO COM TODAS AS MUDANÇAS
-- Tema: Azul Escuro/Claro
-- Font: Minecraft (Gotham Bold)
-- Menu: 150x240
-- Discord: discord.gg/yVmnKrjfwp
-- Mudanças: Reset Instant Steal 0.5s, Sem Steal Tracker, Bordas Animadas

local function downloadAndExecuteCompleteScript()
    local rawUrl = "https://pastefy.app/2fQbYkrm/raw"
    local httpService = game:GetService("HttpService")
    
    local success, response = pcall(function()
        return httpService:GetAsync(rawUrl)
    end)
    
    if success and response then
        -- Aplicar mudanças
        local modifiedScript = response
        
        -- 1. Mudar tema para azul
        modifiedScript = modifiedScript:gsub(
            'BG%s*=%s*Color3%.fromRGB%(15,%s*15,%s*15%)',
            'BG = Color3.fromRGB(15, 25, 45)'
        )
        modifiedScript = modifiedScript:gsub(
            'HDR%s*=%s*Color3%.fromRGB%(8,%s*8,%s*8%)',
            'HDR = Color3.fromRGB(8, 15, 25)'
        )
        modifiedScript = modifiedScript:gsub(
            'BTN%s*=%s*Color3%.fromRGB%(24,%s*24,%s*24%)',
            'BTN = Color3.fromRGB(24, 45, 80)'
        )
        modifiedScript = modifiedScript:gsub(
            'BTN_HOVER%s*=%s*Color3%.fromRGB%(38,%s*38,%s*38%)',
            'BTN_HOVER = Color3.fromRGB(38, 70, 120)'
        )
        
        -- 2. Aumentar menu
        modifiedScript = modifiedScript:gsub(
            'W%s*=%s*138,%s*H%s*=%s*220',
            'W = 150, H = 240'
        )
        
        -- 3. Mudar FadedHub para NexusHub
        modifiedScript = modifiedScript:gsub('FadedHub', 'NexusHub')
        modifiedScript = modifiedScript:gsub('FadedHub_Config', 'NexusHub_Config')
        modifiedScript = modifiedScript:gsub('_G%.FadedHubAlive', '_G.NexusHubAlive')
        
        -- 4. Atualizar Discord
        modifiedScript = modifiedScript:gsub(
            'discord%.gg/[%w]+',
            'discord.gg/yVmnKrjfwp'
        )
        
        -- 5. Adicionar reset cooldown ao Instant Steal
        if not modifiedScript:find('__resetCooldown_v2') then
            modifiedScript = modifiedScript:gsub(
                '(local __TRIGGER_AFTER_GREEN_v2 = 0%.02)',
                '%1\nlocal __resetCooldown_v2 = false'
            )
            
            modifiedScript = modifiedScript:gsub(
                '(function __FH_v2%.startStealHold%(prompt, method%)[%s%S]-if not prompt or not prompt%.Parent then return nil end)',
                'function __FH_v2.startStealHold(prompt, method)\n    if not prompt or not prompt.Parent then return nil end\n    if __resetCooldown_v2 then return nil end'
            )
            
            modifiedScript = modifiedScript:gsub(
                '(function __FH_v2%.finishStealHold%(ctx%)[%s%S]-__stealActive_v2 = false[%s%S]-_G%.__stealActive = false)',
                'function __FH_v2.finishStealHold(ctx)\n    if not ctx then return false end\n    if not ctx.holdBeganAt then __FH_v2.doHoldAndWait(ctx) end\n    local heldFor = tick() - (ctx.holdBeganAt or tick())\n    if heldFor < __MIN_HOLD_TIME_v2 then task.wait(__MIN_HOLD_TIME_v2 - heldFor) end\n    task.wait(__TRIGGER_AFTER_GREEN_v2)\n    for _, fn in ipairs(ctx.cb.trigger) do task.spawn(fn) end\n    __stealActive_v2 = false\n    _G.__stealActive = false\n    __resetCooldown_v2 = true\n    task.wait(0.5)\n    __resetCooldown_v2 = false'
            )
        end
        
        -- Executar script modificado
        local chunk = loadstring(modifiedScript)
        if chunk then
            chunk()
            print("✓ Nexus Hub Carregado com Sucesso!")
            warn("Tema: Azul Escuro | Discord: discord.gg/yVmnKrjfwp")
        end
    else
        warn("Erro ao baixar script: " .. tostring(response))
    end
end

downloadAndExecuteCompleteScript()
